DOMAIN=example.com
WWW_DOMAIN=www.example.com
LETSENCRYPT_EMAIL=you@example.com
# Optional overrides for a purchased certificate mounted in the nginx container.
# The default host files are certificates/fullchain.pem and certificates/privkey.pem.
TLS_CERTIFICATE_PATH=/etc/nginx/certificates/fullchain.pem
TLS_CERTIFICATE_KEY_PATH=/etc/nginx/certificates/privkey.pem
WORDPRESS_VERSION=6.9.4
PHP_VERSION=8.3
WORDPRESS_URL=https://example.com
WORDPRESS_SITE_TITLE="My WordPress Site"
WORDPRESS_ADMIN_USER=admin
WORDPRESS_ADMIN_PASSWORD=admin_password_change_me
WORDPRESS_ADMIN_EMAIL=admin@example.com

MYSQL_ROOT_PASSWORD=rootpassword_change_me
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=wordpress_db_pass_change_me
MYSQL_BIND_ADDRESS=127.0.0.1
MYSQL_PORT=3306

WORDPRESS_DB_NAME=wordpress
WORDPRESS_DB_USER=wordpress
WORDPRESS_DB_PASSWORD=wordpress_db_pass_change_me
